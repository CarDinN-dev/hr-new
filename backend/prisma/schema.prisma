generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleProtection {
  STANDARD
  PROTECTED
  SUPER_ADMIN
}

enum PermissionOverrideEffect {
  GRANT
  DENY
}

enum AccessScopeType {
  SELF
  DIRECT_REPORTS
  MANAGEMENT_TREE
  ASSIGNED_APPROVALS
  ALL_EMPLOYEES
  ALL_SYSTEM
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  PROBATION
  TERMINATED
  RESIGNED
}

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
  TEMPORARY
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

enum AttendanceApprovalStatus {
  PENDING
  APPROVED
  NOT_APPROVED
}

enum LeaveRequestStatus {
  PENDING_LINE_MANAGER
  PENDING_MANAGER
  PENDING_HR
  PENDING_CPO
  PENDING_COO
  RETURNED_FOR_CORRECTION
  BLOCKED_APPROVER_MISSING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveApprovalStage {
  LINE_MANAGER
  MANAGER
  HR
  CPO
  COO
}

enum LeaveRouteType {
  STANDARD
  CPO_TO_COO
  COO_SELF
}

enum LeaveStepStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
  SKIPPED
  REASSIGNED
}

enum LeaveDecisionType {
  APPROVE
  REJECT
  RETURN
  SELF_APPROVE
  OVERRIDE
  CANCEL
  REASSIGN
}

enum WorkflowType {
  LEAVE
}

enum ApproverMode {
  PRIMARY_APPROVER
  ANY_ONE
  NAMED_POOL
}

enum PayrollRunStatus {
  GENERATED
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  PAID
  CANCELLED
}

enum ServiceRequestType {
  SALARY_CERTIFICATE
  EXPERIENCE_CERTIFICATE
  CLEARANCE_CERTIFICATE
}

enum ServiceRequestStatus {
  SUBMITTED
  IN_HR_REVIEW
  GENERATED
  PENDING_HR_APPROVAL
  APPROVED
  PUBLISHED
  REJECTED
  CANCELLED
  REVOKED
}

enum ServiceRequestEventType {
  SUBMITTED
  REVIEW_STARTED
  GENERATED
  SENT_FOR_APPROVAL
  APPROVED
  PUBLISHED
  REJECTED
  CANCELLED
  REVOKED
  REGENERATED
  OVERRIDDEN
}

enum ReviewStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  CLOSED
}

enum DocumentVisibility {
  EMPLOYEE_ONLY
  MANAGER_AND_HR
  HR_ONLY
  PUBLIC
}

enum DocumentScanStatus {
  PENDING
  CLEAN
  REJECTED
  FAILED
}

enum TripStatus {
  PENDING
  APPROVED
  REJECTED
  CLOSED
}

enum ExpenseStatus {
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum LoanRepaymentMode {
  DURATION
  MONTHLY_LIMIT
  MANUAL
}

enum LoanStatus {
  DRAFT
  ACTIVE
  PAUSED
  SETTLED
  CANCELLED
}

enum LoanRepaymentSource {
  PAYROLL
  MANUAL
}

enum LoanRepaymentStatus {
  POSTED
  REVERSED
}

enum RecruitmentJobStatus {
  OPEN
  ON_HOLD
  CLOSED
}

enum CandidateStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum EosStatus {
  DRAFT
  APPROVED
  PAID
}

enum PayrollLineKind {
  BASE_SALARY
  ALLOWANCE
  BONUS
  FIXED_DEDUCTION
  TAX
  LOSS_OF_PAY
  LOAN_REPAYMENT
  MANUAL_ADJUSTMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  TRANSITION
  IMPORT
  ACCESS
  LOGIN
  LOGOUT
  DOWNLOAD
  EXPORT
  OVERRIDE
  REVOKE
}

enum AuditOutcome {
  SUCCESS
  DENIED
  FAILED
}

enum AuditExportFormat {
  CSV
  PDF
}

enum ImportRunStatus {
  DRY_RUN
  APPLIED
  FAILED
}

enum ImportItemStatus {
  CREATED
  SKIPPED
  INVALID
  CONFLICT
}

model User {
  id                       String                      @id @default(uuid())
  email                    String                      @unique
  microsoftObjectId        String?                     @unique
  passwordHash             String?
  localLoginEnabled        Boolean                     @default(true)
  microsoftLoginEnabled    Boolean                     @default(true)
  isActive                 Boolean                     @default(true)
  authorizationVersion     Int                         @default(1)
  employee                 Employee?
  auditEvents              AuditEvent[]
  roles                    UserRole[]                  @relation("AssignedUserRoles")
  rolesAssigned            UserRole[]                  @relation("UserRoleAssigner")
  rolesCreated             Role[]                      @relation("RoleCreator")
  permissionsAssigned      RolePermission[]            @relation("RolePermissionAssigner")
  permissionOverrides      UserPermissionOverride[]    @relation("PermissionOverrideTarget")
  permissionOverridesMade  UserPermissionOverride[]    @relation("PermissionOverrideAssigner")
  sessions                 AuthSession[]
  leaveRequests            LeaveRequest[]              @relation("LeaveRequester")
  leaveDecisions           LeaveDecision[]
  leaveStepAssignments     LeaveApprovalStepAssignee[] @relation("LeaveStepAssignee")
  leaveStepDelegations     LeaveApprovalStepAssignee[] @relation("LeaveStepDelegatedFrom")
  leaveStepsDecided        LeaveApprovalStep[]         @relation("LeaveStepDecider")
  leaveDelegationsFrom     WorkflowDelegation[]        @relation("WorkflowDelegator")
  leaveDelegationsTo       WorkflowDelegation[]        @relation("WorkflowDelegate")
  leaveDelegationsCreated  WorkflowDelegation[]        @relation("WorkflowDelegationCreator")
  workflowPolicies         WorkflowStagePolicy[]       @relation("WorkflowPrimaryApprover")
  workflowPolicyMembership WorkflowStagePolicyMember[]
  serviceRequests          ServiceRequest[]            @relation("ServiceRequester")
  serviceRequestEvents     ServiceRequestEvent[]
  generatedDocuments       GeneratedDocumentVersion[]  @relation("DocumentGenerator")
  approvedDocuments        GeneratedDocumentVersion[]  @relation("DocumentApprover")
  publishedDocuments       GeneratedDocumentVersion[]  @relation("DocumentPublisher")
  revokedDocuments         GeneratedDocumentVersion[]  @relation("DocumentRevoker")
  payrollRunsGenerated     PayrollRun[]                @relation("PayrollRunGenerator")
  payrollRunsApproved      PayrollRun[]                @relation("PayrollRunApprover")
  payrollRunsPublished     PayrollRun[]                @relation("PayrollRunPublisher")
  payrollRunsPaid          PayrollRun[]                @relation("PayrollRunPayer")
  payrollRunsCancelled     PayrollRun[]                @relation("PayrollRunCanceller")
  payrollsRevoked          Payroll[]                   @relation("PayrollRevoker")
  notifications            Notification[]
  idempotencyRecords       IdempotencyRecord[]
  auditExports             AuditExport[]
  auditLegalHolds          AuditLegalHold[]
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  deletedAt                DateTime?

  @@index([authorizationVersion])
  @@index([deletedAt])
}

model Role {
  id          String         @id @default(uuid())
  code        String         @unique @db.VarChar(100)
  displayName String         @db.VarChar(160)
  description String?
  isBuiltIn   Boolean        @default(false)
  protection  RoleProtection @default(STANDARD)
  isActive    Boolean        @default(true)
  version     Int            @default(1)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy   User?            @relation("RoleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  permissions RolePermission[]
  users       UserRole[]

  @@index([isActive])
  @@index([createdById])
  @@map("RbacRole")
}

model Permission {
  id           String   @id @default(uuid())
  code         String   @unique @db.VarChar(160)
  displayName  String   @db.VarChar(200)
  description  String?
  category     String   @db.VarChar(80)
  isProtected  Boolean  @default(false)
  isDeprecated Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles     RolePermission[]
  overrides UserPermissionOverride[]

  @@index([category])
  @@map("RbacPermission")
}

model RolePermission {
  roleId       String
  permissionId String
  assignedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedBy User?      @relation("RolePermissionAssigner", fields: [assignedById], references: [id], onDelete: SetNull)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@index([assignedById])
}

model UserRole {
  id           String    @id @default(uuid())
  userId       String
  roleId       String
  assignedById String?
  assignedAt   DateTime  @default(now())
  expiresAt    DateTime?
  revokedAt    DateTime?
  reason       String?
  updatedAt    DateTime  @updatedAt

  user       User  @relation("AssignedUserRoles", fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("UserRoleAssigner", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([userId, revokedAt, expiresAt])
  @@index([roleId, revokedAt, expiresAt])
  @@index([assignedById])
}

model UserPermissionOverride {
  id            String                   @id @default(uuid())
  userId        String
  permissionId  String
  effect        PermissionOverrideEffect
  scopeType     AccessScopeType
  scopeIds      String[]                 @default([])
  reason        String
  startsAt      DateTime                 @default(now())
  expiresAt     DateTime?
  assignedById  String
  revokedAt     DateTime?
  revokedReason String?
  version       Int                      @default(1)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  user       User       @relation("PermissionOverrideTarget", fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedBy User       @relation("PermissionOverrideAssigner", fields: [assignedById], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt, startsAt, expiresAt])
  @@index([permissionId, effect])
  @@index([assignedById])
}

model AuthSession {
  id                   String    @id @default(uuid())
  userId               String
  tokenHash            String    @unique @db.VarChar(64)
  provider             String    @db.VarChar(32)
  authorizationVersion Int
  ipHash               String?   @db.VarChar(64)
  userAgent            String?   @db.VarChar(512)
  createdAt            DateTime  @default(now())
  reauthenticatedAt    DateTime  @default(now())
  lastSeenAt           DateTime  @default(now())
  expiresAt            DateTime
  revokedAt            DateTime?
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
}

model AuthThrottle {
  key       String   @id
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Employee {
  id                    String           @id @default(uuid())
  userId                String?          @unique
  employeeCode          String           @unique
  firstName             String
  lastName              String
  email                 String           @unique
  phone                 String?
  dateOfBirth           DateTime?
  gender                Gender?
  address               String?
  hireDate              DateTime
  employmentStatus      EmploymentStatus @default(ACTIVE)
  departmentId          String?
  positionId            String?
  managerId             String?
  salary                Decimal          @db.Decimal(12, 2)
  emergencyContactName  String?
  emergencyContactPhone String?
  photo                 String?
  version               Int              @default(1)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  user                  User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  department            Department?             @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  position              JobPosition?            @relation(fields: [positionId], references: [id], onDelete: SetNull)
  manager               Employee?               @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports         Employee[]              @relation("EmployeeManager")
  managedDepartments    Department[]            @relation("DepartmentManager")
  employmentContracts   EmploymentContract[]
  attendanceRecords     Attendance[]
  leaveBalances         LeaveBalance[]
  leaveRequests         LeaveRequest[]          @relation("EmployeeLeaveRequests")
  salaryRecords         SalaryRecord[]
  payrolls              Payroll[]               @relation("EmployeePayrolls")
  serviceRequests       ServiceRequest[]        @relation("ServiceRequestSubject")
  performanceReviews    PerformanceReview[]     @relation("ReviewSubject")
  reviewsGiven          PerformanceReview[]     @relation("ReviewReviewer")
  documents             EmployeeDocument[]      @relation("EmployeeDocuments")
  uploadedDocuments     EmployeeDocument[]      @relation("DocumentUploader")
  createdAnnouncements  Announcement[]          @relation("AnnouncementCreator")
  profile               EmployeeProfile?
  bankAccount           EmployeeBankAccount?
  credentials           EmployeeCredential[]
  benefits              EmployeeBenefitProfile?
  education             EmployeeEducation[]
  businessTrips         BusinessTrip[]
  expenses              EmployeeExpense[]
  loans                 EmployeeLoan[]
  recruitmentCandidates RecruitmentCandidate[]
  eosRecords            EosRecord[]
  attendanceCorrections AttendanceCorrection[]  @relation("AttendanceCorrectionEmployee")
  correctedAttendance   AttendanceCorrection[]  @relation("AttendanceCorrector")

  @@index([departmentId])
  @@index([positionId])
  @@index([managerId])
  @@index([employmentStatus])
  @@index([deletedAt])
}

model Department {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  managerId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  manager         Employee?        @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees       Employee[]       @relation("DepartmentEmployees")
  jobPositions    JobPosition[]
  announcements   Announcement[]
  recruitmentJobs RecruitmentJob[]

  @@index([managerId])
  @@index([deletedAt])
}

model JobPosition {
  id           String    @id @default(uuid())
  title        String
  code         String    @unique
  description  String?
  departmentId String?
  level        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees  Employee[]

  @@index([departmentId])
  @@index([deletedAt])
}

model EmploymentContract {
  id                  String         @id @default(uuid())
  employeeId          String
  contractType        ContractType
  startDate           DateTime
  endDate             DateTime?
  salary              Decimal        @db.Decimal(12, 2)
  currency            String         @default("USD")
  workingHoursPerWeek Int            @default(40)
  status              ContractStatus @default(ACTIVE)
  terms               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([deletedAt])
}

model Attendance {
  id             String                   @id @default(uuid())
  employeeId     String
  attendanceDate DateTime
  checkIn        DateTime?
  checkOut       DateTime?
  isLate         Boolean                  @default(false)
  lateMinutes    Int                      @default(0)
  workingHours   Decimal                  @default(0) @db.Decimal(5, 2)
  status         AttendanceStatus         @default(PRESENT)
  approvalStatus AttendanceApprovalStatus @default(PENDING)
  notes          String?
  version        Int                      @default(1)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?

  employee    Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  corrections AttendanceCorrection[]

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
  @@index([status])
  @@index([deletedAt])
}

model LeaveType {
  id                  String    @id @default(uuid())
  name                String    @unique
  code                String    @unique
  description         String?
  annualAllowanceDays Decimal   @default(0) @db.Decimal(5, 2)
  isPaid              Boolean   @default(true)
  requiresAttachment  Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  balances LeaveBalance[]
  requests LeaveRequest[]

  @@index([deletedAt])
}

model LeaveBalance {
  id          String    @id @default(uuid())
  employeeId  String
  leaveTypeId String
  year        Int
  totalDays   Decimal   @default(0) @db.Decimal(5, 2)
  usedDays    Decimal   @default(0) @db.Decimal(5, 2)
  pendingDays Decimal   @default(0) @db.Decimal(5, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([deletedAt])
}

model LeaveRequest {
  id                         String              @id @default(uuid())
  requesterUserId            String
  employeeId                 String
  leaveTypeId                String
  startDate                  DateTime
  endDate                    DateTime
  totalDays                  Decimal             @db.Decimal(5, 2)
  isHalfDay                  Boolean             @default(false)
  reason                     String?
  status                     LeaveRequestStatus
  routeType                  LeaveRouteType
  currentStage               LeaveApprovalStage?
  workflowVersion            Int                 @default(1)
  requesterRoleCodesSnapshot String[]            @default([])
  managerChainSnapshot       String[]            @default([])
  departmentIdSnapshot       String?
  finalDecisionAt            DateTime?
  rejectionReason            String?
  version                    Int                 @default(1)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  deletedAt                  DateTime?

  requester User                @relation("LeaveRequester", fields: [requesterUserId], references: [id], onDelete: Restrict)
  employee  Employee            @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType LeaveType           @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  steps     LeaveApprovalStep[]
  decisions LeaveDecision[]

  @@index([requesterUserId])
  @@index([employeeId, createdAt])
  @@index([leaveTypeId])
  @@index([status, currentStage])
  @@index([deletedAt])
}

model LeaveApprovalStep {
  id                  String             @id @default(uuid())
  requestId           String
  workflowVersion     Int
  sequence            Int
  stage               LeaveApprovalStage
  assignedRoleCode    String
  status              LeaveStepStatus    @default(PENDING)
  decidedByUserId     String?
  decidedAt           DateTime?
  decisionType        LeaveDecisionType?
  reason              String?
  selfApprovalAllowed Boolean            @default(false)
  isSelfApproval      Boolean            @default(false)
  replacesStepId      String?
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  request      LeaveRequest                @relation(fields: [requestId], references: [id], onDelete: Cascade)
  decidedBy    User?                       @relation("LeaveStepDecider", fields: [decidedByUserId], references: [id], onDelete: Restrict)
  assignees    LeaveApprovalStepAssignee[]
  decisions    LeaveDecision[]
  replacesStep LeaveApprovalStep?          @relation("LeaveStepReplacement", fields: [replacesStepId], references: [id], onDelete: Restrict)
  replacements LeaveApprovalStep[]         @relation("LeaveStepReplacement")

  @@unique([requestId, workflowVersion, sequence])
  @@index([requestId, status])
  @@index([stage, status])
  @@index([decidedByUserId])
}

model LeaveApprovalStepAssignee {
  id                  String    @id @default(uuid())
  stepId              String
  userId              String
  delegatedFromUserId String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  revokedAt           DateTime?

  step          LeaveApprovalStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  user          User              @relation("LeaveStepAssignee", fields: [userId], references: [id], onDelete: Restrict)
  delegatedFrom User?             @relation("LeaveStepDelegatedFrom", fields: [delegatedFromUserId], references: [id], onDelete: Restrict)

  @@unique([stepId, userId])
  @@index([userId, isActive])
  @@index([delegatedFromUserId])
}

model LeaveDecision {
  id             String              @id @default(uuid())
  requestId      String
  stepId         String?
  actorUserId    String
  stage          LeaveApprovalStage?
  decisionType   LeaveDecisionType
  fromStatus     LeaveRequestStatus
  toStatus       LeaveRequestStatus
  reason         String?
  idempotencyKey String?             @db.VarChar(128)
  isOverride     Boolean             @default(false)
  isSelfApproval Boolean             @default(false)
  createdAt      DateTime            @default(now())

  request LeaveRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  step    LeaveApprovalStep? @relation(fields: [stepId], references: [id], onDelete: Restrict)
  actor   User               @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@unique([actorUserId, idempotencyKey])
  @@index([requestId, createdAt])
  @@index([stepId])
  @@index([actorUserId, createdAt])
}

model WorkflowStagePolicy {
  id            String             @id @default(uuid())
  workflowType  WorkflowType
  stage         LeaveApprovalStage
  mode          ApproverMode
  primaryUserId String?
  version       Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  primaryUser User?                       @relation("WorkflowPrimaryApprover", fields: [primaryUserId], references: [id], onDelete: Restrict)
  members     WorkflowStagePolicyMember[]

  @@unique([workflowType, stage])
  @@index([primaryUserId])
}

model WorkflowStagePolicyMember {
  id        String   @id @default(uuid())
  policyId  String
  userId    String
  createdAt DateTime @default(now())

  policy WorkflowStagePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  user   User                @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([policyId, userId])
  @@index([userId])
}

model WorkflowDelegation {
  id              String             @id @default(uuid())
  workflowType    WorkflowType
  stage           LeaveApprovalStage
  delegatorUserId String
  delegateUserId  String
  startsAt        DateTime
  endsAt          DateTime
  reason          String
  createdById     String
  revokedAt       DateTime?
  version         Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  delegator User @relation("WorkflowDelegator", fields: [delegatorUserId], references: [id], onDelete: Restrict)
  delegate  User @relation("WorkflowDelegate", fields: [delegateUserId], references: [id], onDelete: Restrict)
  createdBy User @relation("WorkflowDelegationCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([workflowType, stage, startsAt, endsAt, revokedAt])
  @@index([delegatorUserId])
  @@index([delegateUserId])
}

model SalaryRecord {
  id            String    @id @default(uuid())
  employeeId    String
  baseSalary    Decimal   @db.Decimal(12, 2)
  allowances    Decimal   @default(0) @db.Decimal(12, 2)
  housingAllowance Decimal @default(0) @db.Decimal(12, 2)
  foodAllowance    Decimal @default(0) @db.Decimal(12, 2)
  mobileAllowance  Decimal @default(0) @db.Decimal(12, 2)
  specialAllowance Decimal @default(0) @db.Decimal(12, 2)
  deductions    Decimal   @default(0) @db.Decimal(12, 2)
  bonuses       Decimal   @default(0) @db.Decimal(12, 2)
  overtimeAmount Decimal  @default(0) @db.Decimal(12, 2)
  taxRate       Decimal   @default(0) @db.Decimal(5, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  version       Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([effectiveFrom])
  @@index([deletedAt])
}

model PayrollRun {
  id                 String           @id @default(uuid())
  year               Int
  month              Int
  revision           Int              @default(1)
  status             PayrollRunStatus @default(GENERATED)
  generatedByUserId  String
  generatedAt        DateTime         @default(now())
  approvedByUserId   String?
  approvedAt         DateTime?
  publishedByUserId  String?
  publishedAt        DateTime?
  paidByUserId       String?
  paidAt             DateTime?
  cancelledByUserId  String?
  cancelledAt        DateTime?
  cancellationReason String?
  correctionOfId     String?
  version            Int              @default(1)
  createdAt          DateTime         @default(now())
