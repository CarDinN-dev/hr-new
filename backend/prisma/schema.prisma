generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  HR_ADMIN
  MANAGER
  EMPLOYEE
}

enum Permission {
  EMPLOYEE_READ_ALL
  EMPLOYEE_WRITE
  ATTENDANCE_READ_ALL
  ATTENDANCE_WRITE_ALL
  LEAVE_APPROVE
  PAYROLL_READ
  PAYROLL_WRITE
  DOCUMENT_READ_ALL
  DOCUMENT_WRITE_ALL
  ANNOUNCEMENT_WRITE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  PROBATION
  TERMINATED
  RESIGNED
}

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
  TEMPORARY
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  GENERATED
  APPROVED
  PAID
  CANCELLED
}

enum ReviewStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  CLOSED
}

enum DocumentVisibility {
  EMPLOYEE_ONLY
  MANAGER_AND_HR
  HR_ONLY
  PUBLIC
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  role           Role         @default(EMPLOYEE)
  permissions    Permission[] @default([])
  isActive       Boolean      @default(true)
  sessionVersion Int          @default(0)
  employee       Employee?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([role])
  @@index([deletedAt])
}

model AuthThrottle {
  key       String   @id
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Employee {
  id                    String           @id @default(uuid())
  userId                String?          @unique
  employeeCode          String           @unique
  firstName             String
  lastName              String
  email                 String           @unique
  phone                 String?
  dateOfBirth           DateTime?
  gender                Gender?
  address               String?
  hireDate              DateTime
  employmentStatus      EmploymentStatus @default(ACTIVE)
  departmentId          String?
  positionId            String?
  managerId             String?
  salary                Decimal          @db.Decimal(12, 2)
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  user                  User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  department            Department?          @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  position              JobPosition?         @relation(fields: [positionId], references: [id], onDelete: SetNull)
  manager               Employee?            @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports         Employee[]           @relation("EmployeeManager")
  managedDepartments    Department[]         @relation("DepartmentManager")
  employmentContracts   EmploymentContract[]
  attendanceRecords     Attendance[]
  leaveBalances         LeaveBalance[]
  leaveRequests         LeaveRequest[]       @relation("EmployeeLeaveRequests")
  managedLeaveRequests  LeaveRequest[]       @relation("LeaveManager")
  approvedLeaveRequests LeaveRequest[]       @relation("LeaveApprover")
  salaryRecords         SalaryRecord[]
  payrolls              Payroll[]            @relation("EmployeePayrolls")
  approvedPayrolls      Payroll[]            @relation("PayrollApprover")
  performanceReviews    PerformanceReview[]  @relation("ReviewSubject")
  reviewsGiven          PerformanceReview[]  @relation("ReviewReviewer")
  documents             EmployeeDocument[]   @relation("EmployeeDocuments")
  uploadedDocuments     EmployeeDocument[]   @relation("DocumentUploader")
  createdAnnouncements  Announcement[]       @relation("AnnouncementCreator")

  @@index([departmentId])
  @@index([positionId])
  @@index([managerId])
  @@index([employmentStatus])
  @@index([deletedAt])
}

model Department {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  managerId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  manager       Employee?      @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees     Employee[]     @relation("DepartmentEmployees")
  jobPositions  JobPosition[]
  announcements Announcement[]

  @@index([managerId])
  @@index([deletedAt])
}

model JobPosition {
  id           String    @id @default(uuid())
  title        String
  code         String    @unique
  description  String?
  departmentId String?
  level        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees  Employee[]

  @@index([departmentId])
  @@index([deletedAt])
}

model EmploymentContract {
  id                  String         @id @default(uuid())
  employeeId          String
  contractType        ContractType
  startDate           DateTime
  endDate             DateTime?
  salary              Decimal        @db.Decimal(12, 2)
  currency            String         @default("USD")
  workingHoursPerWeek Int            @default(40)
  status              ContractStatus @default(ACTIVE)
  terms               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([deletedAt])
}

model Attendance {
  id             String           @id @default(uuid())
  employeeId     String
  attendanceDate DateTime
  checkIn        DateTime?
  checkOut       DateTime?
  isLate         Boolean          @default(false)
  lateMinutes    Int              @default(0)
  workingHours   Decimal          @default(0) @db.Decimal(5, 2)
  status         AttendanceStatus @default(PRESENT)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
  @@index([status])
  @@index([deletedAt])
}

model LeaveType {
  id                  String    @id @default(uuid())
  name                String    @unique
  code                String    @unique
  description         String?
  annualAllowanceDays Decimal   @default(0) @db.Decimal(5, 2)
  isPaid              Boolean   @default(true)
  requiresAttachment  Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  balances LeaveBalance[]
  requests LeaveRequest[]

  @@index([deletedAt])
}

model LeaveBalance {
  id          String    @id @default(uuid())
  employeeId  String
  leaveTypeId String
  year        Int
  totalDays   Decimal   @default(0) @db.Decimal(5, 2)
  usedDays    Decimal   @default(0) @db.Decimal(5, 2)
  pendingDays Decimal   @default(0) @db.Decimal(5, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([deletedAt])
}

model LeaveRequest {
  id              String             @id @default(uuid())
  employeeId      String
  leaveTypeId     String
  startDate       DateTime
  endDate         DateTime
  totalDays       Decimal            @db.Decimal(5, 2)
  isHalfDay       Boolean            @default(false)
  reason          String?
  status          LeaveRequestStatus @default(PENDING)
  managerId       String?
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  employee   Employee  @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  manager    Employee? @relation("LeaveManager", fields: [managerId], references: [id], onDelete: SetNull)
  approvedBy Employee? @relation("LeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([managerId])
  @@index([approvedById])
  @@index([status])
  @@index([deletedAt])
}

model SalaryRecord {
  id            String    @id @default(uuid())
  employeeId    String
  baseSalary    Decimal   @db.Decimal(12, 2)
  allowances    Decimal   @default(0) @db.Decimal(12, 2)
  deductions    Decimal   @default(0) @db.Decimal(12, 2)
  bonuses       Decimal   @default(0) @db.Decimal(12, 2)
  taxRate       Decimal   @default(0) @db.Decimal(5, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([effectiveFrom])
  @@index([deletedAt])
}

model Payroll {
  id           String        @id @default(uuid())
  employeeId   String
  year         Int
  month        Int
  baseSalary   Decimal       @db.Decimal(12, 2)
  allowances   Decimal       @default(0) @db.Decimal(12, 2)
  deductions   Decimal       @default(0) @db.Decimal(12, 2)
  bonuses      Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal       @default(0) @db.Decimal(12, 2)
  grossPay     Decimal       @db.Decimal(12, 2)
  netPay       Decimal       @db.Decimal(12, 2)
  status       PayrollStatus @default(GENERATED)
  approvedById String?
  approvedAt   DateTime?
  paidAt       DateTime?
  generatedAt  DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  employee   Employee  @relation("EmployeePayrolls", fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy Employee? @relation("PayrollApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([employeeId, year, month])
  @@index([employeeId])
  @@index([year, month])
  @@index([status])
  @@index([deletedAt])
}

model PerformanceReview {
  id                String       @id @default(uuid())
  employeeId        String
  reviewerId        String
  reviewPeriodStart DateTime
  reviewPeriodEnd   DateTime
  rating            Decimal      @db.Decimal(3, 2)
  goals             String?
  strengths         String?
  improvements      String?
  comments          String?
  status            ReviewStatus @default(DRAFT)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  employee Employee @relation("ReviewSubject", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer Employee @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([reviewerId])
  @@index([status])
  @@index([deletedAt])
}

model EmployeeDocument {
  id           String             @id @default(uuid())
  employeeId   String
  documentType String
  fileName     String
  fileUrl      String
  uploadedById String
  expiryDate   DateTime?
  visibility   DocumentVisibility @default(MANAGER_AND_HR)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  employee   Employee @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy Employee @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([uploadedById])
  @@index([documentType])
  @@index([expiryDate])
  @@index([deletedAt])
}

model Announcement {
  id            String    @id @default(uuid())
  title         String
  content       String
  audienceRoles Role[]    @default([])
  departmentId  String?
  createdById   String
  publishedAt   DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy  Employee    @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([departmentId])
  @@index([createdById])
  @@index([isActive])
  @@index([deletedAt])
}

model HrConsoleState {
  id          String   @id
  data        Json
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HrConsoleStateBackup {
  id             String   @id @default(uuid())
  data           Json
  stateUpdatedAt DateTime
  kind           String
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}
