model ImportItem {
  id         String           @id @default(uuid())
  runId      String
  entityType String
  legacyId   String?
  targetId   String?
  sourceHash String
  status     ImportItemStatus
  reason     String?
  createdAt  DateTime         @default(now())

  run ImportRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, entityType, sourceHash])
  @@index([runId, status])
}
